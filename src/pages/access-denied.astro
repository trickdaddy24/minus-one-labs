---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Access Denied — Minus One Labs">
  <div class="min-h-screen bg-[#060f1a] flex items-center justify-center px-6 text-center">
    <div class="max-w-md">
      <div class="text-6xl mb-6">🚫</div>
      <h1 class="text-3xl font-heading font-semibold mb-4">Access Denied</h1>
      <p class="text-zinc-400 mb-8 leading-relaxed">
        Your IP address has been blocked from accessing this site. If you believe this is a mistake, please contact us.
      </p>
      <a href="mailto:admin@stunna.xyz" class="text-[#635bff] hover:underline text-sm">admin@stunna.xyz</a>
    </div>
  </div>
</Layout>

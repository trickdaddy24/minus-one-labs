---
import Layout from '../layouts/Layout.astro';

const session = (Astro.locals as any).session;
const db = (Astro.locals as any).runtime?.env?.DB;

// Get all quotes for this user's email
const { results: quotes } = await db.prepare(
  `SELECT q.*, qn.submitted_at as questionnaire_submitted
   FROM quotes q
   LEFT JOIN questionnaires qn ON qn.quote_id = q.id
   WHERE q.email = ?
   ORDER BY q.created_at DESC`
).bind(session.email).all();

const statusLabel: Record<string, string> = {
  pending: 'Pending Review',
  proposal_sent: 'Proposal Sent',
  accepted: 'Accepted',
  launched: 'Launched 🚀',
};

const statusColor: Record<string, string> = {
  pending: 'bg-yellow-500/20 text-yellow-300 border-yellow-500/30',
  proposal_sent: 'bg-blue-500/20 text-blue-300 border-blue-500/30',
  accepted: 'bg-green-500/20 text-green-300 border-green-500/30',
  launched: 'bg-purple-500/20 text-purple-300 border-purple-500/30',
};
---

<Layout title="My Dashboard — Minus One Labs">
  <div class="min-h-screen bg-[#0a2540] px-6 py-12">
    <div class="max-w-3xl mx-auto">

      <div class="flex items-center justify-between mb-10">
        <div>
          <h1 class="text-3xl font-heading font-semibold">My Dashboard</h1>
          <p class="text-zinc-400 text-sm mt-1">{session.email}</p>
        </div>
        <form method="POST" action="/api/auth/logout">
          <button class="text-sm text-zinc-400 hover:text-white border border-white/20 px-4 py-2 rounded-xl transition">
            Sign out
          </button>
        </form>
      </div>

      {quotes.length === 0 ? (
        <div class="bg-[#1a3a66] rounded-3xl p-10 text-center">
          <p class="text-zinc-300 mb-4">No quotes yet. Submit an inquiry from the home page to get started.</p>
          <a href="/#contact" class="bg-[#635bff] hover:bg-[#7e6bfd] px-6 py-3 rounded-2xl font-semibold text-sm transition">
            Request a Quote
          </a>
        </div>
      ) : (
        <div class="space-y-6">
          {quotes.map((q: any) => (
            <div class="bg-[#1a3a66] border border-white/10 rounded-3xl p-6">
              <div class="flex items-start justify-between gap-4 mb-4">
                <div>
                  <h2 class="font-semibold text-lg">{q.company || q.name}</h2>
                  <p class="text-zinc-400 text-xs mt-1">Submitted {new Date(q.created_at).toLocaleDateString()}</p>
                </div>
                <span class={`text-xs font-medium px-3 py-1 rounded-full border ${statusColor[q.status] ?? 'bg-white/10 text-white'}`}>
                  {statusLabel[q.status] ?? q.status}
                </span>
              </div>

              {q.admin_note && (
                <div class="bg-[#0a2540] rounded-2xl p-4 mb-4 text-sm text-zinc-300">
                  <span class="text-zinc-500 text-xs block mb-1">Note from the lab:</span>
                  {q.admin_note}
                </div>
              )}

              {q.status === 'accepted' && !q.questionnaire_submitted && (
                <a href={`/questionnaire?quote_id=${q.id}`}
                  class="inline-block bg-[#635bff] hover:bg-[#7e6bfd] px-5 py-2 rounded-xl text-sm font-semibold transition">
                  Fill Out Questionnaire →
                </a>
              )}

              {q.questionnaire_submitted && (
                <p class="text-green-400 text-sm">✓ Questionnaire submitted — we're on it!</p>
              )}
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</Layout>

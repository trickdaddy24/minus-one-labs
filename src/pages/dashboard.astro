---
import Layout from '../layouts/Layout.astro';

const session = (Astro.locals as any).session;
const db = (Astro.locals as any).runtime?.env?.DB;

// Quotes for this user
const { results: quotes } = await db.prepare(
  `SELECT q.*, qn.submitted_at as questionnaire_submitted
   FROM quotes q
   LEFT JOIN questionnaires qn ON qn.quote_id = q.id
   WHERE q.email = ?
   ORDER BY q.created_at DESC`
).bind(session.email).all();

// User info
const user = await db.prepare(
  `SELECT id, email, created_at, display_mode FROM users WHERE email = ?`
).bind(session.email).first() as { id: string; email: string; created_at: string; display_mode: string | null } | null;

// Site default display mode
const siteSetting = await db.prepare(
  `SELECT value FROM site_settings WHERE key = 'default_display_mode'`
).first() as { value: string } | null;

const userTheme = user?.display_mode ?? siteSetting?.value ?? 'dark';
const isLight = userTheme === 'light';

// Unlock account features once any quote is accepted
const hasAccepted = (quotes as any[]).some(q => ['accepted', 'launched'].includes(q.status));

// Active subscription = accepted/launched quote with a tier set
const activeSub = (quotes as any[]).find(q => ['accepted', 'launched'].includes(q.status) && q.price_tier);

const TIER_LABELS: Record<string, string> = { basic: 'Basic', standard: 'Standard', premium: 'Premium' };
const TIER_PRICES: Record<string, string> = { basic: '$500', standard: '$1,500', premium: '$3,000' };
const HOSTING_LABELS: Record<string, string> = { starter: 'Starter', growth: 'Growth', pro: 'Pro' };
const HOSTING_MONTHLY: Record<string, string> = { starter: '$6/mo', growth: '$12/mo', pro: '$24/mo' };
const HOSTING_ANNUAL: Record<string, string>  = { starter: '$72/yr', growth: '$144/yr', pro: '$288/yr' };

const statusLabel: Record<string, string> = {
  pending: 'Pending Review',
  proposal_sent: 'Proposal Ready',
  proposal_rejected: 'Proposal Declined',
  accepted: 'Accepted',
  launched: 'Launched 🚀',
};
const statusColor: Record<string, string> = isLight ? {
  pending:           'bg-yellow-100 text-yellow-700 border-yellow-300',
  proposal_sent:     'bg-blue-100 text-blue-700 border-blue-300',
  proposal_rejected: 'bg-red-100 text-red-700 border-red-300',
  accepted:          'bg-green-100 text-green-700 border-green-300',
  launched:          'bg-purple-100 text-purple-700 border-purple-300',
} : {
  pending:           'bg-yellow-500/20 text-yellow-300 border-yellow-500/30',
  proposal_sent:     'bg-blue-500/20 text-blue-300 border-blue-500/30',
  proposal_rejected: 'bg-red-500/20 text-red-300 border-red-500/30',
  accepted:          'bg-green-500/20 text-green-300 border-green-500/30',
  launched:          'bg-purple-500/20 text-purple-300 border-purple-500/30',
};

const bg       = isLight ? 'bg-slate-100'           : 'bg-[#0a2540]';
const cardBg   = isLight ? 'bg-white border-slate-200' : 'bg-[#1a3a66] border-white/10';
const innerBg  = isLight ? 'bg-slate-50 border border-slate-200' : 'bg-[#0a2540]';
const inputCls = isLight
  ? 'bg-slate-50 border-slate-200 focus:border-[#635bff] text-slate-900 placeholder-slate-400'
  : 'bg-[#0a2540] border-white/10 focus:border-[#635bff] text-white placeholder-zinc-600';
const labelCls = isLight ? 'text-slate-500' : 'text-zinc-400';
const valueCls = isLight ? 'text-slate-800' : 'text-zinc-200';
const headCls  = isLight ? 'text-slate-900' : 'text-white';
const mutedCls = isLight ? 'text-slate-500' : 'text-zinc-400';
const borderCls = isLight ? 'border-slate-200' : 'border-white/10';
---

<Layout title="My Dashboard — Minus One Labs">
  <div class={`min-h-screen px-6 py-12 ${bg}`}>
    <div class="max-w-3xl mx-auto">

      <!-- Header -->
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class={`text-2xl font-heading font-semibold ${headCls}`}>My Dashboard</h1>
          <p class={`text-sm mt-0.5 ${labelCls}`}>{session.email}</p>
        </div>
        <form method="POST" action="/api/auth/logout">
          <button class={`text-sm px-4 py-2 rounded-xl border transition ${isLight ? 'border-slate-300 text-slate-600 hover:text-slate-900' : 'border-white/20 text-zinc-400 hover:text-white'}`}>
            Sign out
          </button>
        </form>
      </div>

      <!-- Tabs -->
      <div class={`flex gap-1 mb-8 border-b pb-0 ${borderCls}`}>
        {['My Quotes', 'My Account'].map((tab, i) => (
          <button
            data-tab={i}
            class={`dash-tab px-5 py-3 text-sm font-medium border-b-2 transition -mb-px ${i === 0 ? 'border-[#635bff] text-[#635bff]' : `border-transparent ${labelCls}`}`}
          >{tab}</button>
        ))}
      </div>

      <!-- ── Tab 0: My Quotes ── -->
      <div id="dash-tab-0" class="dash-panel">
        {quotes.length === 0 ? (
          <div class={`border rounded-3xl p-10 text-center ${cardBg}`}>
            <p class={`mb-4 ${labelCls}`}>No quotes yet. Submit an inquiry from the home page to get started.</p>
            <a href="/#contact" class="bg-[#635bff] hover:bg-[#7e6bfd] text-white px-6 py-3 rounded-2xl font-semibold text-sm transition inline-block">
              Request a Quote
            </a>
          </div>
        ) : (
          <div class="space-y-6">
            {(quotes as any[]).map((q) => (
              <div class={`border rounded-3xl p-6 ${cardBg}`}>
                <div class="flex items-start justify-between gap-4 mb-4">
                  <div>
                    <h2 class={`font-semibold text-lg ${headCls}`}>{q.company || q.name}</h2>
                    <p class={`text-xs mt-1 ${labelCls}`}>Submitted {new Date(q.created_at).toLocaleDateString()}</p>
                  </div>
                  <span class={`text-xs font-medium px-3 py-1 rounded-full border ${statusColor[q.status] ?? 'bg-white/10 text-white'}`}>
                    {statusLabel[q.status] ?? q.status}
                  </span>
                </div>

                {/* Proposal block */}
                {q.proposal_text && (
                  <div class={`rounded-2xl p-4 mb-4 ${innerBg}`}>
                    <span class={`text-xs uppercase tracking-wider font-medium block mb-2 ${mutedCls}`}>Your Proposal</span>
                    <div class="flex flex-wrap gap-2 mb-3">
                      {q.price_tier && (
                        <div class="inline-flex items-center gap-1.5 bg-[#635bff]/20 text-[#a5a0ff] text-xs font-semibold px-3 py-1 rounded-full">
                          {TIER_LABELS[q.price_tier]} Plan · {TIER_PRICES[q.price_tier]}
                        </div>
                      )}
                      {q.hosting_tier && (
                        <div class="inline-flex items-center gap-1.5 bg-teal-500/20 text-teal-300 text-xs font-semibold px-3 py-1 rounded-full">
                          {HOSTING_LABELS[q.hosting_tier]} Hosting · {HOSTING_MONTHLY[q.hosting_tier]}
                        </div>
                      )}
                    </div>
                    <p class={`text-sm leading-relaxed whitespace-pre-wrap ${valueCls}`}>{q.proposal_text}</p>
                  </div>
                )}

                {/* Admin note */}
                {q.admin_note && (
                  <div class={`rounded-2xl p-4 mb-4 text-sm ${innerBg} ${valueCls}`}>
                    <span class={`text-xs block mb-1 ${mutedCls}`}>Note from the team:</span>
                    {q.admin_note}
                  </div>
                )}

                {/* Accept / Reject CTA */}
                {q.status === 'proposal_sent' && (
                  <div class={`rounded-2xl p-4 mb-4 border ${isLight ? 'bg-blue-50 border-blue-200' : 'bg-blue-500/10 border-blue-500/30'}`}>
                    <p class={`text-sm mb-3 ${isLight ? 'text-slate-700' : 'text-zinc-200'}`}>
                      Ready to move forward? Accept the proposal to lock in your plan and unlock the project questionnaire.
                    </p>
                    <div class="flex flex-wrap gap-3">
                      <button
                        data-accept-id={q.id}
                        class="accept-proposal-btn bg-[#635bff] hover:bg-[#7e6bfd] text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition"
                      >
                        Accept Proposal →
                      </button>
                      <button
                        data-reject-id={q.id}
                        class="reject-proposal-btn text-sm font-medium px-5 py-2.5 rounded-xl border transition text-red-400 border-red-400/40 hover:border-red-400/70 hover:bg-red-500/10"
                      >
                        Decline
                      </button>
                    </div>
                  </div>
                )}

                {/* Rejected state */}
                {q.status === 'proposal_rejected' && (
                  <div class={`rounded-2xl p-4 mb-4 border ${isLight ? 'bg-red-50 border-red-200' : 'bg-red-500/10 border-red-500/30'}`}>
                    <p class={`text-sm ${isLight ? 'text-red-700' : 'text-red-300'}`}>
                      You declined this proposal. We've been notified and will follow up with a revised offer shortly.
                    </p>
                  </div>
                )}

                {q.status === 'accepted' && !q.questionnaire_submitted && (
                  <a href={`/questionnaire?quote_id=${q.id}`}
                    class="inline-block bg-[#635bff] hover:bg-[#7e6bfd] text-white px-5 py-2 rounded-xl text-sm font-semibold transition">
                    Fill Out Questionnaire →
                  </a>
                )}
                {q.questionnaire_submitted && (
                  <p class={`text-sm ${isLight ? 'text-green-700' : 'text-green-400'}`}>✓ Questionnaire submitted — we're building your site!</p>
                )}
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- ── Tab 1: My Account ── -->
      <div id="dash-tab-1" class="dash-panel hidden space-y-5">

        <!-- Preferences -->
        <div class={`border rounded-2xl p-6 ${cardBg}`}>
          <h2 class={`font-semibold text-base mb-4 ${headCls}`}>Preferences</h2>
          <div class="flex items-center justify-between">
            <span class={`text-sm ${labelCls}`}>Display mode</span>
            <div class="flex gap-2">
              <button class={`theme-btn text-xs px-4 py-2 rounded-lg border transition ${!isLight ? 'bg-[#635bff] border-[#635bff] text-white' : `border-slate-300 ${labelCls}`}`} data-mode="dark">Dark</button>
              <button class={`theme-btn text-xs px-4 py-2 rounded-lg border transition ${isLight ? 'bg-[#635bff] border-[#635bff] text-white' : 'border-white/20 text-zinc-400 hover:border-white/40'}`} data-mode="light">Light</button>
            </div>
          </div>
        </div>

        <!-- User Information -->
        <div class={`border rounded-2xl p-6 ${cardBg}`}>
          <h2 class={`font-semibold text-base mb-4 ${headCls}`}>User Information</h2>
          <div class="space-y-3 mb-5">
            <div class="flex justify-between text-sm">
              <span class={labelCls}>Email</span>
              <span class={valueCls}>{session.email}</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class={labelCls}>Member since</span>
              <span class={valueCls}>{user?.created_at ? new Date(user.created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) : '—'}</span>
            </div>
          </div>

          {hasAccepted ? (
            <div>
              <p class={`text-xs mb-3 ${mutedCls}`}>Set a password for your account (optional — magic link always works).</p>
              <div class="space-y-2">
                <div class="relative">
                  <input id="newPassword" type="password" placeholder="New password"
                    class={`w-full border rounded-xl px-4 py-2.5 text-sm outline-none transition pr-14 ${inputCls}`} />
                  <button type="button" id="toggleNewPw" class={`absolute right-3 top-1/2 -translate-y-1/2 text-xs px-2 py-1 rounded transition ${isLight ? 'text-slate-400 hover:text-slate-700' : 'text-zinc-500 hover:text-zinc-200'}`}>Show</button>
                </div>
                <!-- Strength bar -->
                <div class="space-y-1.5" id="strengthSection">
                  <div class="flex gap-1">
                    <div class="strength-seg h-1 flex-1 rounded-full bg-slate-300 transition-colors" id="seg1"></div>
                    <div class="strength-seg h-1 flex-1 rounded-full bg-slate-300 transition-colors" id="seg2"></div>
                    <div class="strength-seg h-1 flex-1 rounded-full bg-slate-300 transition-colors" id="seg3"></div>
                    <div class="strength-seg h-1 flex-1 rounded-full bg-slate-300 transition-colors" id="seg4"></div>
                  </div>
                  <ul class="grid grid-cols-2 gap-x-4 gap-y-0.5" id="reqList">
                    <li class="req-item text-xs flex items-center gap-1.5" data-req="length"><span class="req-icon">○</span> 8+ characters</li>
                    <li class="req-item text-xs flex items-center gap-1.5" data-req="upper"><span class="req-icon">○</span> Uppercase letter</li>
                    <li class="req-item text-xs flex items-center gap-1.5" data-req="lower"><span class="req-icon">○</span> Lowercase letter</li>
                    <li class="req-item text-xs flex items-center gap-1.5" data-req="number"><span class="req-icon">○</span> Number</li>
                    <li class="req-item text-xs flex items-center gap-1.5" data-req="special"><span class="req-icon">○</span> Special character</li>
                  </ul>
                </div>
                <div class="relative">
                  <input id="confirmPassword" type="password" placeholder="Confirm password"
                    class={`w-full border rounded-xl px-4 py-2.5 text-sm outline-none transition pr-14 ${inputCls}`} />
                  <button type="button" id="toggleConfirmPw" class={`absolute right-3 top-1/2 -translate-y-1/2 text-xs px-2 py-1 rounded transition ${isLight ? 'text-slate-400 hover:text-slate-700' : 'text-zinc-500 hover:text-zinc-200'}`}>Show</button>
                </div>
                <div class="flex items-center gap-3 pt-1">
                  <button id="savePasswordBtn" class="bg-[#635bff] hover:bg-[#7e6bfd] text-white text-sm px-4 py-2 rounded-xl transition font-medium">Update Password</button>
                  <span id="passwordMsg" class="text-xs hidden"></span>
                </div>
              </div>
            </div>
          ) : (
            <p class={`text-xs ${mutedCls}`}>Password management is available once your proposal is accepted.</p>
          )}
        </div>

        <!-- Manage Subscription -->
        <div class={`border rounded-2xl p-6 ${cardBg}`}>
          <h2 class={`font-semibold text-base mb-4 ${headCls}`}>Manage Subscription</h2>
          {activeSub ? (
            <div class="space-y-3">
              <div class="flex justify-between text-sm">
                <span class={labelCls}>Status</span>
                <span class={`text-xs font-semibold px-3 py-1 rounded-full ${isLight ? 'bg-green-100 text-green-700' : 'bg-green-500/20 text-green-300'}`}>Active</span>
              </div>
              <div class="flex justify-between text-sm">
                <span class={labelCls}>Plan</span>
                <span class={valueCls}>{TIER_LABELS[activeSub.price_tier] ?? activeSub.price_tier}</span>
              </div>
              <div class="flex justify-between text-sm">
                <span class={labelCls}>One-time fee</span>
                <span class={valueCls}>{TIER_PRICES[activeSub.price_tier] ?? '—'}</span>
              </div>
              {activeSub.hosting_tier && (
                <>
                  <div class={`border-t pt-3 mt-1 ${borderCls}`}></div>
                  <div class="flex justify-between text-sm">
                    <span class={labelCls}>Hosting plan</span>
                    <span class={valueCls}>{HOSTING_LABELS[activeSub.hosting_tier] ?? activeSub.hosting_tier}</span>
                  </div>
                  <div class="flex justify-between text-sm">
                    <span class={labelCls}>Monthly</span>
                    <span class={valueCls}>{HOSTING_MONTHLY[activeSub.hosting_tier] ?? '—'}</span>
                  </div>
                  <div class="flex justify-between text-sm">
                    <span class={labelCls}>Billed annually</span>
                    <span class={valueCls}>{HOSTING_ANNUAL[activeSub.hosting_tier] ?? '—'}</span>
                  </div>
                </>
              )}
            </div>
          ) : (
            <div class="flex flex-wrap items-center gap-3">
              <span class={`text-xs font-semibold px-3 py-1 rounded-full ${isLight ? 'bg-slate-200 text-slate-600' : 'bg-zinc-500/20 text-zinc-400'}`}>No active subscription</span>
              <span class={`text-xs ${mutedCls}`}>A plan will appear here once your proposal is accepted.</span>
            </div>
          )}
        </div>

        <!-- Get Support -->
        <div class={`border rounded-2xl p-6 ${cardBg}`}>
          <h2 class={`font-semibold text-base mb-1 ${headCls}`}>Get Support</h2>
          <p class={`text-sm mb-4 ${labelCls}`}>Here's how to get support:</p>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <span class="text-[#635bff] text-base mt-0.5">✉</span>
              <div>
                <p class={`text-sm ${valueCls}`}>Send an email to <a href="mailto:support@minus-one-labs.com" class="text-[#635bff] hover:underline">support@minus-one-labs.com</a></p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-[#635bff] text-base mt-0.5">💬</span>
              <div>
                <p class={`text-sm ${valueCls}`}>Send a message via the <a href="/#contact" class="text-[#635bff] hover:underline">contact form</a></p>
                <p class={`text-xs mt-0.5 ${mutedCls}`}>We'll be notified instantly via Telegram and Pushover.</p>
              </div>
            </li>
          </ul>
        </div>

      </div>
    </div>
  </div>
</Layout>

<script>
  const isLight = document.querySelector('.min-h-screen')?.classList.contains('bg-slate-100') ?? false;

  // Reject proposal
  document.querySelectorAll('.reject-proposal-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const reason = prompt('Let us know why you\'re declining (optional):') ?? '';
      if (reason === null) return; // cancelled prompt
      const quoteId = (btn as HTMLElement).dataset.rejectId!;
      (btn as HTMLButtonElement).disabled = true;
      (btn as HTMLButtonElement).textContent = 'Declining...';
      const res = await fetch('/api/quotes/reject', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ quote_id: quoteId, reason: reason || undefined }),
      });
      if (res.ok) {
        location.reload();
      } else {
        alert('Something went wrong. Please try again or contact support.');
        (btn as HTMLButtonElement).disabled = false;
        (btn as HTMLButtonElement).textContent = 'Decline';
      }
    });
  });

  // Accept proposal
  document.querySelectorAll('.accept-proposal-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('Accept this proposal? This will lock in your plan and unlock the project questionnaire.')) return;
      const quoteId = (btn as HTMLElement).dataset.acceptId!;
      (btn as HTMLButtonElement).disabled = true;
      (btn as HTMLButtonElement).textContent = 'Accepting...';
      const res = await fetch('/api/quotes/accept', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ quote_id: quoteId }),
      });
      if (res.ok) {
        location.reload();
      } else {
        alert('Something went wrong. Please try again or contact support.');
        (btn as HTMLButtonElement).disabled = false;
        (btn as HTMLButtonElement).textContent = 'Accept Proposal →';
      }
    });
  });

  // Tab switching
  document.querySelectorAll('.dash-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const i = btn.getAttribute('data-tab');
      document.querySelectorAll('.dash-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll('.dash-tab').forEach(b => {
        b.classList.remove('border-[#635bff]', 'text-[#635bff]');
        b.classList.add('border-transparent');
      });
      document.getElementById(`dash-tab-${i}`)!.classList.remove('hidden');
      btn.classList.add('border-[#635bff]', 'text-[#635bff]');
      btn.classList.remove('border-transparent');
    });
  });

  // Theme toggle
  document.querySelectorAll('.theme-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const mode = (btn as HTMLElement).dataset.mode!;
      await fetch('/api/user/account', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ display_mode: mode }),
      });
      location.reload();
    });
  });

  // Password show/hide toggles
  function makeToggle(btnId: string, inputId: string) {
    const btn = document.getElementById(btnId) as HTMLButtonElement | null;
    const input = document.getElementById(inputId) as HTMLInputElement | null;
    if (!btn || !input) return;
    btn.addEventListener('click', () => {
      const hidden = input.type === 'password';
      input.type = hidden ? 'text' : 'password';
      btn.textContent = hidden ? 'Hide' : 'Show';
    });
  }
  makeToggle('toggleNewPw', 'newPassword');
  makeToggle('toggleConfirmPw', 'confirmPassword');

  // Password strength meter
  const pwInput = document.getElementById('newPassword') as HTMLInputElement | null;
  if (pwInput) {
    const isLightMode = document.querySelector('.min-h-screen')?.classList.contains('bg-slate-100') ?? false;
    const segColors = ['bg-red-500', 'bg-orange-400', 'bg-yellow-400', 'bg-green-500'];
    const inactiveColor = isLightMode ? 'bg-slate-200' : 'bg-zinc-700';
    const reqPassColor = isLightMode ? 'text-green-700' : 'text-green-400';
    const reqFailColor = isLightMode ? 'text-slate-400' : 'text-zinc-500';

    const checks: Record<string, (v: string) => boolean> = {
      length:  v => v.length >= 8,
      upper:   v => /[A-Z]/.test(v),
      lower:   v => /[a-z]/.test(v),
      number:  v => /[0-9]/.test(v),
      special: v => /[^A-Za-z0-9]/.test(v),
    };

    pwInput.addEventListener('input', () => {
      const val = pwInput.value;
      const passed = Object.values(checks).filter(fn => fn(val)).length;

      // Update segments
      for (let i = 1; i <= 4; i++) {
        const seg = document.getElementById(`seg${i}`)!;
        seg.className = `strength-seg h-1 flex-1 rounded-full transition-colors ${i <= passed ? segColors[passed - 1] : inactiveColor}`;
      }

      // Update requirement items
      document.querySelectorAll('.req-item').forEach(li => {
        const req = (li as HTMLElement).dataset.req!;
        const ok = checks[req]?.(val) ?? false;
        const icon = li.querySelector('.req-icon')!;
        icon.textContent = ok ? '✓' : '○';
        li.className = `req-item text-xs flex items-center gap-1.5 ${ok ? reqPassColor : reqFailColor}`;
      });
    });
  }

  // Password update
  const savePasswordBtn = document.getElementById('savePasswordBtn');
  if (savePasswordBtn) {
    const checks: Record<string, (v: string) => boolean> = {
      length:  v => v.length >= 8,
      upper:   v => /[A-Z]/.test(v),
      lower:   v => /[a-z]/.test(v),
      number:  v => /[0-9]/.test(v),
      special: v => /[^A-Za-z0-9]/.test(v),
    };

    savePasswordBtn.addEventListener('click', async () => {
      const newPw = (document.getElementById('newPassword') as HTMLInputElement).value;
      const confirmPw = (document.getElementById('confirmPassword') as HTMLInputElement).value;
      const msg = document.getElementById('passwordMsg')!;

      msg.className = 'text-xs hidden';

      if (!newPw || !confirmPw) {
        msg.textContent = 'Please fill in both fields.';
        msg.className = 'text-xs text-red-400';
        return;
      }

      const failed = Object.entries(checks).filter(([, fn]) => !fn(newPw));
      if (failed.length > 0) {
        msg.textContent = 'Password does not meet all requirements.';
        msg.className = 'text-xs text-red-400';
        return;
      }

      if (newPw !== confirmPw) {
        msg.textContent = 'Passwords do not match.';
        msg.className = 'text-xs text-red-400';
        return;
      }

      (savePasswordBtn as HTMLButtonElement).textContent = 'Saving...';
      (savePasswordBtn as HTMLButtonElement).disabled = true;

      const res = await fetch('/api/user/account', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ new_password: newPw }),
      });

      if (res.ok) {
        msg.textContent = '✓ Password updated.';
        msg.className = 'text-xs text-green-400';
        (document.getElementById('newPassword') as HTMLInputElement).value = '';
        (document.getElementById('confirmPassword') as HTMLInputElement).value = '';
        document.querySelectorAll('.strength-seg').forEach(s => {
          s.className = 'strength-seg h-1 flex-1 rounded-full bg-slate-300 transition-colors';
        });
        document.querySelectorAll('.req-item').forEach(li => {
          li.querySelector('.req-icon')!.textContent = '○';
        });
      } else {
        const err = await res.json() as { error?: string };
        msg.textContent = err.error ?? 'Something went wrong.';
        msg.className = 'text-xs text-red-400';
      }
      (savePasswordBtn as HTMLButtonElement).textContent = 'Update Password';
      (savePasswordBtn as HTMLButtonElement).disabled = false;
    });
  }
</script>

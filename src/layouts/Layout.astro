---
interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
}

const {
  title = 'Minus One Labs • Modern Websites That Rank & Convert',
  description = 'Minus One Labs builds fast, beautiful, high-converting websites with integrated reviews and SEO.',
  bodyClass = 'bg-[#0a2540] text-white',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    <script>
      // Inactivity auto-logout (30 min default, only on authenticated pages)
      if (document.cookie.includes('mol_session')) {
        let t: ReturnType<typeof setTimeout>;
        const TIMEOUT = 30 * 60 * 1000;
        const reset = () => { clearTimeout(t); t = setTimeout(() => fetch('/api/auth/logout', { method: 'POST' }).then(() => location.href = '/login'), TIMEOUT); };
        ['mousemove','keydown','click','scroll','touchstart'].forEach(e => document.addEventListener(e, reset, { passive: true }));
        reset();
      }
    </script>
  </head>
  <body class={`${bodyClass} font-sans`}>
    <slot />
  </body>
</html>

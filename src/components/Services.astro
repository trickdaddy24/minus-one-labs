---
const services = [
  {
    icon: '🌐',
    title: 'One-Page Website',
    description:
      'About, services, contact form, and live visitor comments — professionally designed and live in 14 days.',
  },
  {
    icon: '⭐',
    title: 'Reviews & Ratings',
    description:
      'Google review widget, star rating display, and a live comment system so visitors can vouch for your business.',
  },
  {
    icon: '🔍',
    title: 'SEO Built In',
    description:
      'Schema markup, fast load times, and local search optimization so you rank on Google from launch day.',
  },
  {
    icon: '🔒',
    title: 'Hosting Included',
    description:
      'Deployed on Cloudflare Pages — global CDN, SSL certificate, and blazing fast load times at no extra cost.',
  },
];
---

<section id="services" class="py-24 bg-[#0f2b4f]">
  <div class="max-w-7xl mx-auto px-6">
    <h2 class="text-5xl font-heading font-semibold text-center mb-4">
      Everything your business needs online
    </h2>
    <p class="text-center text-zinc-400 mb-16">One flat price. No hidden fees. Launched in 14 days.</p>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {
        services.map((s) => (
          <div class="bg-[#1a3a66] p-8 rounded-3xl hover:ring-2 hover:ring-[#635bff]/50 transition">
            <div class="text-5xl mb-6">{s.icon}</div>
            <h3 class="text-xl font-semibold mb-3">{s.title}</h3>
            <p class="text-zinc-300 text-sm leading-relaxed">{s.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

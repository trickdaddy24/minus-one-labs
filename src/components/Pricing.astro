---
const tiers = [
  {
    name: 'Basic',
    price: 500,
    tagline: 'Get online fast',
    highlight: false,
    features: [
      'Custom one-page website',
      'Your branding, colors & content',
      'Mobile-first responsive design',
      'Contact form with lead notifications',
      'Basic on-page SEO',
      'Cloudflare Pages hosting + SSL',
      'Domain setup assistance',
      'Live in 14 days',
    ],
    cta: 'Get Started',
  },
  {
    name: 'Standard',
    price: 1500,
    tagline: 'Most popular',
    highlight: true,
    features: [
      'Everything in Basic',
      'Custom fonts & color palette',
      'Additional sections (Portfolio, FAQ)',
      'Photo editing & optimization',
      'Google Business profile integration',
      'Contact form customization',
      'Schema markup for local SEO',
      'Dual-row testimonials section',
    ],
    cta: 'Get Started',
  },
  {
    name: 'Premium',
    price: 3000,
    tagline: 'Full white-glove service',
    highlight: false,
    features: [
      'Everything in Standard',
      'Full custom design',
      'Professional copywriting',
      'Testimonials setup & sourcing',
      'Google Analytics & Search Console',
      'Review widget integration',
      'Basic booking calendar embed',
      '3 months of updates & support',
    ],
    cta: 'Get Started',
  },
];
---

<section id="pricing" class="py-24 bg-[#0a2540]">
  <div class="max-w-7xl mx-auto px-6">
    <h2 class="text-5xl font-heading font-semibold text-center mb-4">Simple, transparent pricing</h2>
    <p class="text-center text-zinc-400 mb-16">One-time fee. No monthly subscriptions. No surprises.</p>

    <div class="grid md:grid-cols-3 gap-8">
      {tiers.map(tier => (
        <div class={`relative rounded-3xl p-8 flex flex-col ${
          tier.highlight
            ? 'bg-[#635bff] ring-2 ring-[#635bff]'
            : 'bg-[#1a3a66] border border-white/10'
        }`}>
          {tier.highlight && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-white text-[#635bff] text-xs font-bold px-4 py-1.5 rounded-full">
              MOST POPULAR
            </div>
          )}

          <div class="mb-6">
            <h3 class="text-xl font-semibold mb-1">{tier.name}</h3>
            <p class={`text-sm mb-4 ${tier.highlight ? 'text-white/80' : 'text-zinc-400'}`}>{tier.tagline}</p>
            <div class="flex items-end gap-1">
              <span class="text-5xl font-bold">${tier.price.toLocaleString()}</span>
              <span class={`text-sm mb-2 ${tier.highlight ? 'text-white/70' : 'text-zinc-400'}`}>one-time</span>
            </div>
          </div>

          <ul class="space-y-3 mb-8 flex-1">
            {tier.features.map(f => (
              <li class="flex items-start gap-2 text-sm">
                <svg class={`w-4 h-4 mt-0.5 flex-shrink-0 ${tier.highlight ? 'text-white' : 'text-[#635bff]'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
                <span class={tier.highlight ? 'text-white/90' : 'text-zinc-300'}>{f}</span>
              </li>
            ))}
          </ul>

          <a href="/#contact"
            class={`block text-center py-4 rounded-2xl font-semibold transition ${
              tier.highlight
                ? 'bg-white text-[#635bff] hover:bg-white/90'
                : 'bg-[#635bff] hover:bg-[#7e6bfd] text-white'
            }`}>
            {tier.cta}
          </a>
        </div>
      ))}
    </div>

    <p class="text-center text-zinc-500 text-sm mt-10">
      Need something custom? <a href="/#contact" class="text-[#635bff] hover:underline">Let's talk</a> — we'll build a package around your business.
    </p>
  </div>
</section>

---
interface Props { registrationOpen?: boolean; }
const { registrationOpen = true } = Astro.props;
---

<section id="contact" class="py-24 bg-[#0a2540]">
  <div class="max-w-2xl mx-auto px-6">
    <h2 class="text-5xl font-heading font-semibold text-center mb-4">
      Ready to launch your new website?
    </h2>
    <p class="text-center text-zinc-400 mb-12">
      Tell us about your business. We'll reply within 24 hours with a custom proposal and a live
      demo concept for your site.
    </p>

    {!registrationOpen && (
      <div class="text-center py-12 px-8 bg-[#0f1f35] border border-white/10 rounded-3xl">
        <div class="text-4xl mb-4">🚧</div>
        <h3 class="text-xl font-semibold text-white mb-2">We're not taking new inquiries right now</h3>
        <p class="text-zinc-400 text-sm">
          Our calendar is currently full. Check back soon — we open new spots periodically.<br />
          In the meantime, feel free to <a href="mailto:support@minus-one-labs.com" class="text-[#635bff] hover:underline">send us an email</a>.
        </p>
      </div>
    )}

    <form id="leadForm" class={`space-y-6 ${!registrationOpen ? 'hidden' : ''}`}>
      <div class="grid md:grid-cols-2 gap-6">
        <input
          type="text"
          name="name"
          placeholder="Your name"
          required
          class="bg-[#1a3a66] border border-white/20 focus:border-[#635bff] rounded-2xl px-6 py-5 outline-none text-white placeholder-zinc-400 w-full"
        />
        <input
          type="email"
          name="email"
          placeholder="Business email"
          required
          class="bg-[#1a3a66] border border-white/20 focus:border-[#635bff] rounded-2xl px-6 py-5 outline-none text-white placeholder-zinc-400 w-full"
        />
      </div>
      <input
        type="text"
        name="company"
        placeholder="Company name"
        class="w-full bg-[#1a3a66] border border-white/20 focus:border-[#635bff] rounded-2xl px-6 py-5 outline-none text-white placeholder-zinc-400"
      />

      <div>
        <label class="block text-sm mb-3 font-medium text-zinc-300">What do you need?</label>
        <div class="grid grid-cols-2 gap-3 text-sm">
          <label class="flex items-center gap-2">
            <input type="checkbox" name="needs" value="New modern website" checked class="accent-[#635bff]" />
            New modern website
          </label>
          <label class="flex items-center gap-2">
            <input type="checkbox" name="needs" value="Review & rating system" class="accent-[#635bff]" />
            Review & rating system
          </label>
          <label class="flex items-center gap-2">
            <input type="checkbox" name="needs" value="Google SEO optimization" class="accent-[#635bff]" />
            Google SEO optimization
          </label>
          <label class="flex items-center gap-2">
            <input type="checkbox" name="needs" value="All of the above" id="allCheckbox" class="accent-[#635bff]" />
            All of the above
          </label>
        </div>
      </div>

      <textarea
        name="message"
        rows="4"
        placeholder="Tell us about your business and goals..."
        class="w-full bg-[#1a3a66] border border-white/20 focus:border-[#635bff] rounded-3xl px-6 py-5 outline-none text-white placeholder-zinc-400"
      ></textarea>

      <!-- Promo Code -->
      <div class="flex gap-3">
        <input
          type="text"
          id="promoInput"
          placeholder="Promo code (optional)"
          class="flex-1 bg-[#1a3a66] border border-white/20 focus:border-[#635bff] rounded-2xl px-6 py-4 outline-none text-white placeholder-zinc-400 uppercase"
        />
        <button type="button" id="applyPromo"
          class="px-5 py-4 border border-white/20 hover:border-[#635bff] rounded-2xl text-sm font-medium transition">
          Apply
        </button>
      </div>
      <div id="promoMsg" class="hidden text-sm px-2"></div>
      <input type="hidden" id="promoCode" name="promo_code" value="" />

      <!-- Cloudflare Turnstile -->
      <div class="cf-turnstile" data-sitekey="0x4AAAAAADCCZGNsfzblCwGe" data-theme="dark"></div>

      <button
        type="submit"
        id="submitBtn"
        class="w-full bg-[#635bff] hover:bg-[#7e6bfd] py-6 text-xl font-semibold rounded-3xl transition"
      >
        Submit Inquiry — Let's Build
      </button>

      <!-- Status messages -->
      <div id="successMsg" class="hidden text-center p-4 bg-green-500/20 border border-green-500/40 rounded-2xl text-green-300">
        🎉 Inquiry received! We'll be in touch within 24 hours.
      </div>
      <div id="errorMsg" class="hidden text-center p-4 bg-red-500/20 border border-red-500/40 rounded-2xl text-red-300">
        Something went wrong. Please email us directly.
      </div>
    </form>

    <p class="text-xs text-zinc-500 text-center mt-8">
      Your info stays private. Real inquiries get a personal reply from the lab.
    </p>
  </div>
</section>

<script>
  // Promo code
  document.getElementById('applyPromo')!.addEventListener('click', async () => {
    const code = (document.getElementById('promoInput') as HTMLInputElement).value.trim();
    const msg = document.getElementById('promoMsg')!;
    const hidden = document.getElementById('promoCode') as HTMLInputElement;
    if (!code) return;
    const res = await fetch('/api/promo/validate', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ code }),
    });
    const data = await res.json() as { valid: boolean; discount_pct?: number; error?: string };
    msg.classList.remove('hidden', 'text-green-400', 'text-red-400');
    if (data.valid) {
      msg.textContent = `✓ ${data.discount_pct}% discount applied!`;
      msg.classList.add('text-green-400');
      hidden.value = code;
    } else {
      msg.textContent = data.error ?? 'Invalid code';
      msg.classList.add('text-red-400');
      hidden.value = '';
    }
  });

  // "All of the above" toggle logic
  const allCheckbox = document.getElementById('allCheckbox') as HTMLInputElement;
  const individualBoxes = document.querySelectorAll<HTMLInputElement>('input[name="needs"]:not(#allCheckbox)');

  allCheckbox.addEventListener('change', () => {
    individualBoxes.forEach(cb => cb.checked = allCheckbox.checked);
  });

  individualBoxes.forEach(cb => {
    cb.addEventListener('change', () => {
      allCheckbox.checked = Array.from(individualBoxes).every(c => c.checked);
    });
  });

  const form = document.getElementById('leadForm') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement | null;

  if (form && submitBtn) {
    const successMsg = document.getElementById('successMsg')!;
    const errorMsg = document.getElementById('errorMsg')!;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      successMsg.classList.add('hidden');
      errorMsg.classList.add('hidden');

      const data = new FormData(form);

      try {
        const res = await fetch('/api/contact', { method: 'POST', body: data });
        if (res.ok) {
          successMsg.classList.remove('hidden');
          form.reset();
        } else {
          const json = await res.json().catch(() => ({})) as { error?: string };
          errorMsg.textContent = json.error ?? 'Something went wrong. Please email us directly.';
          errorMsg.classList.remove('hidden');
        }
      } catch {
        errorMsg.textContent = 'Something went wrong. Please email us directly.';
        errorMsg.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = "Submit Inquiry — Let's Build";
      }
    });
  }
</script>
